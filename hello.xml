<mujoco>
    <option gravity="0 0 -9.81"/>   <!-- explicit, same as default -->
    <asset>
        <texture name="grid" type="2d" builtin="checker"
                 rgb1="0.1 0.1 0.1" rgb2="0.9 0.9 0.9"
                 width="300" height="300"/>
        <material name="grid_mat" texture="grid" texrepeat="5 5"/>
    </asset>

    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
        <geom type="plane" size="1 1 0.1"  material="grid_mat"/>

        <body pos="0 0 2">
            <joint type="free"/>
            <geom type="box" size=".1 .2 .3" rgba=".6 .8 1 1"/>
        </body>

        <body pos="1 0 1">
            <joint type="free"/>
            <geom type="box" size=".3 .2 .1" rgba=".8 .9 1 1"/>
        </body>

        <body pos="0 .3 .3" euler="40 20 0">
            <joint type="free"/>
            <geom type="box" size=".1 .2 .3" rgba=".6 .8 1 1"/>
        </body>

        <body pos=".3 0 .3">
            <joint type="free"/>
            <geom type="box" size=".1 .2 .3" rgba=".2 .8 1 1"/>
        </body>

        <body pos="0 1 .5" euler="0 90 0">
            <joint type="free"/>
            <geom type="sphere" size=".1 .2 .3" rgba=".1 .8 .9 1"/>
        </body>

    </worldbody>
</mujoco>